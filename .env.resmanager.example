# SwiftRay Resource Manager Configuration
# Copy this file to .env.resmanager and customize

# Xray version to download (default: latest)
# XRAY_VERSION=1.8.4

# Download mirror (default: GitHub releases)
# XRAY_MIRROR=https://github.com/XTLS/Xray-core/releases/latest/download

# Custom geo file URLs
# GEO_IP_URL=https://github.com/XTLS/Xray-core/releases/latest/download/geoip.dat
# GEO_SITE_URL=https://github.com/XTLS/Xray-core/releases/latest/download/geosite.dat

# Output directory for bundled resources
# RESOURCES_DIR=resources
